<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1090"
             d:DesignHeight="679"
             x:Class="WojoPersistentEditor.Views.EditorView">

    <Grid RowDefinitions="42,*,38">
        <Grid Grid.Row="0"
              ColumnDefinitions="362,*,36,285"
              Margin="0,0,8,0">
            <TextBlock Grid.Column="0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="NAME" />

            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="VALUES" />

            <Image Grid.Column="2"
                   Width="19"
                   Height="19"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Source="/Assets/lupa.PNG"
                   Stretch="Uniform" />

            <TextBox x:Name="Browser"
                     Grid.Column="3"
                     Height="30"
                     Padding="10,0"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Background="{StaticResource InputBrush}"
                     BorderThickness="0"
                     CornerRadius="10"
                     Watermark="Search variables..."
                     TextChanged="Browser_TextChanged" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,4"
                Background="{StaticResource AppBackgroundBrush}"
                ClipToBounds="True">
            <Grid>
                <StackPanel x:Name="VariablesPanel"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top" />

                <TextBlock x:Name="EmptyStateText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="18"
                           Foreground="#B9B7C8"
                           Text="No variables to show." />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="18">
            <Button x:Name="LeftButton"
                    Width="38"
                    Height="26"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="&lt;"
                    Click="LeftButton_Click" />

            <TextBlock x:Name="PageNumber"
                       MinWidth="58"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="17"
                       FontWeight="Bold"
                       Text="0 / 0" />

            <Button x:Name="RightButton"
                    Width="38"
                    Height="26"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="&gt;"
                    Click="RightButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
